{
  "name": "faster-chat-monorepo",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:server\"",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:server": "cd server && bun run dev",
    "build": "bun run build:frontend && bun run build:server",
    "build:frontend": "cd frontend && bun run build",
    "build:server": "cd server && bun run build",
    "start": "cd server && bun run start",
    "clean": "rm -rf frontend/dist server/dist node_modules frontend/node_modules server/node_modules packages/*/node_modules",
    "install:all": "bun install",
    "format": "prettier --write \"frontend/src/**/*.{js,jsx,ts,tsx,css,json}\" \"server/src/**/*.{js,jsx,ts,tsx,json}\"",
    "format:check": "prettier --check \"frontend/src/**/*.{js,jsx,ts,tsx,css,json}\" \"server/src/**/*.{js,jsx,ts,tsx,json}\"",
    "test": "cd server && bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1337hero/faster-chat"
  },
  "license": "MIT",
  "author": "1337 Hero, LLC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.9",
    "fuzzysort": "^3.1.0"
  }
}
